{
  "info": {
    "name": "Property Listing Platform API",
    "_postman_id": "property-listing-platform-api",
    "description": "API collection for the Property Listing Platform backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://api.localhost/api",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"agent\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user. Role must be one of: `admin`, `agent`."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"token\": \"1|abc123...\",\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"role\": \"agent\"\n  }\n}"
            },
            {
              "name": "422 Unprocessable Entity",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"The email has already been taken.\",\n  \"errors\": {\n    \"email\": [\"The email has already been taken.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('auth_token', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate a user and retrieve a Sanctum token. The test script automatically saves the token to the `auth_token` collection variable."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"token\": \"1|abc123...\",\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"role\": \"agent\"\n  }\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Invalid credentials.\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Revoke the current user's Sanctum token. Requires authentication."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Logged out successfully.\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Admin / Users",
      "description": "Endpoints require authentication and the `admin` role.",
      "item": [
        {
          "name": "Force Logout User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/:user/force-logout",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", ":user", "force-logout"],
              "variable": [
                {
                  "key": "user",
                  "value": "1",
                  "description": "The ID of the user to log out from all devices."
                }
              ]
            },
            "description": "Revoke all Sanctum tokens for a given user, logging them out from all devices. Requires `admin` role."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"User has been logged out from all devices.\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            },
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"This action is unauthorized.\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"No query results for model [App\\\\Modules\\\\Users\\\\Models\\\\UserModel].\"\n}"
            }
          ]
        },
        {
          "name": "Toggle User Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/:user/toggle-status",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", ":user", "toggle-status"],
              "variable": [
                {
                  "key": "user",
                  "value": "1",
                  "description": "The ID of the user whose active status to toggle."
                }
              ]
            },
            "description": "Toggle the `is_active` flag for a user. Cannot be used on admin users. Requires `admin` role."
          },
          "response": [
            {
              "name": "200 OK — Activated",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"User activated successfully.\",\n  \"user\": {\n    \"id\": 2,\n    \"name\": \"Jane Agent\",\n    \"email\": \"jane@example.com\",\n    \"role\": \"agent\",\n    \"is_active\": true\n  }\n}"
            },
            {
              "name": "200 OK — Deactivated",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"User deactivated successfully.\",\n  \"user\": {\n    \"id\": 2,\n    \"name\": \"Jane Agent\",\n    \"email\": \"jane@example.com\",\n    \"role\": \"agent\",\n    \"is_active\": false\n  }\n}"
            },
            {
              "name": "403 Forbidden — Admin target",
              "status": "Forbidden",
              "code": 403,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Cannot change status of an admin user.\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Amenities",
      "description": "Amenity lookup endpoints. All require a Sanctum bearer token.",
      "item": [
        {
          "name": "List Amenities",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/amenities",
              "host": ["{{base_url}}"],
              "path": ["amenities"]
            },
            "description": "Return all amenities ordered alphabetically. Requires authentication."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "[\n  { \"id\": 1, \"name\": \"Air Conditioning\", \"createdAt\": \"2026-06-12T00:00:00.000000Z\", \"updatedAt\": \"2026-06-12T00:00:00.000000Z\" },\n  { \"id\": 2, \"name\": \"Balcony\", \"createdAt\": \"2026-06-12T00:00:00.000000Z\", \"updatedAt\": \"2026-06-12T00:00:00.000000Z\" },\n  { \"id\": 3, \"name\": \"Gym\", \"createdAt\": \"2026-06-12T00:00:00.000000Z\", \"updatedAt\": \"2026-06-12T00:00:00.000000Z\" },\n  { \"id\": 4, \"name\": \"Parking\", \"createdAt\": \"2026-06-12T00:00:00.000000Z\", \"updatedAt\": \"2026-06-12T00:00:00.000000Z\" },\n  { \"id\": 5, \"name\": \"Swimming Pool\", \"createdAt\": \"2026-06-12T00:00:00.000000Z\", \"updatedAt\": \"2026-06-12T00:00:00.000000Z\" }\n]"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Properties",
      "description": "Property listing endpoints. All require a Sanctum bearer token.",
      "item": [
        {
          "name": "List Properties",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/properties?page=1",
              "host": ["{{base_url}}"],
              "path": ["properties"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number for pagination."
                }
              ]
            },
            "description": "Return a paginated list of all property listings (15 per page, ordered by newest first). Requires authentication."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"current_page\": 1,\n  \"data\": [\n    {\n      \"agentId\": 1,\n      \"title\": \"Beautiful House in Sydney\",\n      \"description\": \"A stunning property with ocean views.\",\n      \"price\": \"750000.00\",\n      \"propertyType\": \"house\",\n      \"status\": \"for_sale\",\n      \"bedrooms\": 3,\n      \"bathrooms\": 2,\n      \"floorArea\": \"180.50\",\n      \"lotArea\": \"350.00\",\n      \"floors\": 2,\n      \"address\": \"12 Harbour St\",\n      \"city\": \"Sydney\",\n      \"province\": \"New South Wales\",\n      \"country\": \"AU\",\n      \"zipCode\": \"2000\",\n      \"latitude\": \"-33.8688000\",\n      \"longitude\": \"151.2093000\",\n      \"createdAt\": \"2026-06-12T00:00:00.000000Z\",\n      \"updatedAt\": \"2026-06-12T00:00:00.000000Z\",\n      \"id\": 1,\n      \"amenities\": [\n        { \"id\": 1, \"name\": \"Swimming Pool\", \"createdAt\": \"2026-06-12T00:00:00.000000Z\", \"updatedAt\": \"2026-06-12T00:00:00.000000Z\" },\n        { \"id\": 2, \"name\": \"Gym\", \"createdAt\": \"2026-06-12T00:00:00.000000Z\", \"updatedAt\": \"2026-06-12T00:00:00.000000Z\" }\n      ]\n    }\n  ],\n  \"first_page_url\": \"http://api.localhost/api/properties?page=1\",\n  \"from\": 1,\n  \"last_page\": 1,\n  \"last_page_url\": \"http://api.localhost/api/properties?page=1\",\n  \"next_page_url\": null,\n  \"path\": \"http://api.localhost/api/properties\",\n  \"per_page\": 15,\n  \"prev_page_url\": null,\n  \"to\": 1,\n  \"total\": 1\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            }
          ]
        },
        {
          "name": "Get Property",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/properties/:id",
              "host": ["{{base_url}}"],
              "path": ["properties", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "The ID of the property."
                }
              ]
            },
            "description": "Return a single property listing by ID. Requires authentication."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"agentId\": 1,\n  \"title\": \"Beautiful House in Sydney\",\n  \"description\": \"A stunning property with ocean views.\",\n  \"price\": \"750000.00\",\n  \"propertyType\": \"house\",\n  \"status\": \"for_sale\",\n  \"bedrooms\": 3,\n  \"bathrooms\": 2,\n  \"floorArea\": \"180.50\",\n  \"lotArea\": \"350.00\",\n  \"floors\": 2,\n  \"address\": \"12 Harbour St\",\n  \"city\": \"Sydney\",\n  \"province\": \"New South Wales\",\n  \"country\": \"AU\",\n  \"zipCode\": \"2000\",\n  \"latitude\": \"-33.8688000\",\n  \"longitude\": \"151.2093000\",\n  \"createdAt\": \"2026-06-12T00:00:00.000000Z\",\n  \"updatedAt\": \"2026-06-12T00:00:00.000000Z\",\n  \"id\": 1,\n  \"amenities\": []\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Property not found.\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            }
          ]
