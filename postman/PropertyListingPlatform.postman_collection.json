            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            },
            {
              "name": "422 Unprocessable Entity",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"The propertyType field is required.\",\n  \"errors\": {\n    \"title\": [\"The title field is required.\"],\n    \"price\": [\"The price field is required.\"],\n    \"propertyType\": [\"The propertyType field is required.\"],\n    \"address\": [\"The address field is required.\"],\n    \"city\": [\"The city field is required.\"],\n    \"province\": [\"The province field is required.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated House in Sydney\",\n  \"status\": \"sold\",\n  \"price\": \"800000.00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/properties/:id",
              "host": ["{{base_url}}"],
              "path": ["properties", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "The ID of the property to update."
                }
              ]
            },
            "description": "Partially update a property listing. Only the authenticated agent who owns the property may update it. All fields are optional. `propertyType` must be one of: `house`, `apartment`, `condo`, `townhouse`, `land`, `commercial`. `status` must be one of: `for_sale`, `for_rent`, `sold`, `rented`."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"agentId\": 1,\n  \"title\": \"Updated House in Sydney\",\n  \"description\": \"A stunning property with ocean views.\",\n  \"price\": \"800000.00\",\n  \"propertyType\": \"house\",\n  \"status\": \"sold\",\n  \"bedrooms\": 3,\n  \"bathrooms\": 2,\n  \"floorArea\": \"180.50\",\n  \"lotArea\": \"350.00\",\n  \"floors\": 2,\n  \"address\": \"12 Harbour St\",\n  \"city\": \"Sydney\",\n  \"province\": \"New South Wales\",\n  \"country\": \"AU\",\n  \"zipCode\": \"2000\",\n  \"latitude\": \"-33.8688000\",\n  \"longitude\": \"151.2093000\",\n  \"createdAt\": \"2026-06-12T00:00:00.000000Z\",\n  \"updatedAt\": \"2026-06-12T01:00:00.000000Z\",\n  \"id\": 1,\n  \"amenities\": []\n}"
            },
            {
